# Vue.js 项目 .gitignore

# 依赖
node_modules/

# 构建输出
/dist
.output/
.nuxt/

# 开发环境
.env.local
.env.development.local
.env.test.local
.env.production.local

# 编辑器
.idea
.vscode
*.swp
*.swo
*.suo
*.ntvs*
*.njsproj
*.sln

# 操作系统
.DS_Store
Thumbs.db

# 测试覆盖率
coverage/
*.lcov

# 日志
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.log

# 缓存
.cache/
.temp/
.tmp/

# ESLint
.eslintcache

# Vite
.vite/

# 运行时数据
pids/
*.pid
*.seed
*.pid.lock

# Optional npm cache directory
.npm

# Optional REPL history
.node_repl_history

# Output of 'npm pack'
*.tgz

# Yarn Integrity file
.yarn-integrity

# parcel-bundler cache
.parcel-cache
